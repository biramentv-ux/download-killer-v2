{
  "manifest_version": 3,
  "name": "DyrakArmy Downloader",
  "version": "1.0.1",
  "description": "Queue and download tracks/clips with DyrakArmy directly from your browser.",
  "action": {
    "default_title": "DyrakArmy",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "activeTab",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "https://dyrakarmy.online/*",
    "https://www.dyrakarmy.online/*"
  ]
}
