{
  "manifest_version": 3,
  "name": "DyrakArmy Downloader",
  "version": "1.2.0",
  "description": "Queue and download tracks/clips with DyrakArmy directly from your browser.",
  "action": {
    "default_title": "DyrakArmy",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://open.spotify.com/*"
      ],
      "js": [
        "web_player_content.js"
      ],
      "css": [
        "web_player_content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "activeTab",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "https://dyrakarmy.eu/*",
    "https://www.dyrakarmy.eu/*",
    "https://dyrakarmy.online/*",
    "https://www.dyrakarmy.online/*",
    "https://open.spotify.com/*"
  ]
}
