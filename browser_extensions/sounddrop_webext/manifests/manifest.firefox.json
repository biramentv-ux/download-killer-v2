{
  "manifest_version": 3,
  "name": "SoundDrop Downloader",
  "version": "1.0.0",
  "description": "Queue and download tracks/clips with SoundDrop directly from your browser.",
  "action": {
    "default_title": "SoundDrop",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "activeTab",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "sounddrop-extension@sounddrop.app",
      "strict_min_version": "115.0"
    }
  }
}
