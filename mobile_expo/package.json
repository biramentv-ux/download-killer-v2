{
  "name": "mobile_expo",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.0",
    "expo": "~56.0.5",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.12",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:ios:production": "eas build -p ios --profile production",
    "build:android:production": "eas build -p android --profile production",
    "build:stores": "eas build --profile production",
    "submit:ios": "eas submit -p ios --profile production",
    "submit:android": "eas submit -p android --profile production"
