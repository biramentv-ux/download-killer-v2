{
  "name": "mobile_expo",
  "version": "1.0.1",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.0",
    "expo": "~56.0.5",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.12",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "export:web": "expo export --platform web --output-dir dist/web",
    "export:ios": "expo export --platform ios --output-dir dist/native/ios",
    "export:android": "expo export --platform android --output-dir dist/native/android",
    "export:native": "npm run export:ios && npm run export:android"
  },
  "private": true
}
