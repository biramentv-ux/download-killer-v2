{
  "name": "sounddrop-worker",
  "version": "12.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.jsonc",
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "telegram:setup": "node scripts/setup-telegram-platform.mjs",
    "db:repair:telegram": "node scripts/repair-telegram-schema.mjs",
    "build:tg-archive-seed": "node scripts/build-telegram-archive-seed.mjs --out telegram_archive_seed.sql",
    "secrets:rotate": "node scripts/rotate-secrets.mjs --generate-missing --apply",
    "validate:single-bot": "node scripts/validate-single-telegram-bot.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
